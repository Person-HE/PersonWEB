# ===== 阿维的平台 - 后端环境变量 =====
# 复制本文件为 .env 并填写真实值

# 服务端口
PORT=8787

# JWT 密钥（请改成长随机字符串，建议 64 位以上）
JWT_SECRET=please-change-this-to-a-long-random-string-at-least-64-chars-long-abcdefgh1234567890

# 管理员账号（首次 init 时写入数据库）
ADMIN_USERNAME=admin

# 管理员初始密码（首次 init 时哈希后写入数据库，之后请删除本项或修改密码）
ADMIN_INITIAL_PASSWORD=please-change-this-password-immediately

# 允许的管理员登录 IP 白名单（逗号分隔，留空表示不限制）
# 强烈建议填写你的固定 IP，提供双重保护
# 例如：127.0.0.1,::1,192.168.1.100
ALLOWED_IPS=

# 前端域名（用于 CORS 白名单）
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174

# JWT 过期时间
JWT_EXPIRES_IN=8h

# 数据库文件路径（lowdb JSON 文件）
DB_PATH=./data/db.json
